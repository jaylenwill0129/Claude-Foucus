# Public Supabase browser configuration.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Live data configuration.
# For production, put provider secrets behind a backend proxy instead of shipping them to the browser.

# Preferred: a backend/Supabase Edge Function that returns normalized options/futures quotes.
VITE_LIVE_DATA_PROXY_URL=
VITE_CATALYST_PROXY_URL=
VITE_REUTERS_NEWS_PROXY_URL=
VITE_DOW_JONES_NEWS_PROXY_URL=

# Alpha Vantage options/equity data. Local testing only; prefer ALPHA_VANTAGE_API_KEY on the backend proxy.
VITE_ALPHA_VANTAGE_API_KEY=

# Polygon-style options/stock REST access.
# Browser-side use is for local testing only; prefer POLYGON_API_KEY in the backend proxy.
VITE_POLYGON_API_KEY=
VITE_OPTIONS_UNDERLYINGS=SOFI,PLTR,HOOD,HPE,MGM,SMCI,IONQ,RGTI,TMHC,CIFR,GFS,LUNR,WOLF,PLUG,KULR,CHPT,WULF,IREN,QBTS,RKLB,ASTS,RDW,BE
VITE_DISCOVERY_SYMBOLS=MMED,MNMD,CMPS,ATAI,CYBN,GHRS,SAVA,ALKS,VRNA,MLTX,TERN,XOS,WKHS,LEV,REE,GOEV,RIVN,WCT,TJGC,SDOT,STAK,STI,SBEV,SVCO,ASTC,CRWD,FIVE,AVGO
VITE_MAX_OPTION_UNIVERSE=100
VITE_OPTION_CONTRACTS_PER_SYMBOL=12
VITE_OPTION_SCAN_CONCURRENCY=6
VITE_ALPHA_VANTAGE_FALLBACK_SYMBOLS=4
VITE_DIRECT_OPTION_BATCH_SIZE=36
VITE_PROVIDER_TIMEOUT_MS=6000

# Broad catalyst/news radar. Uses proxy/Polygon news first, then Alpha Vantage NEWS_SENTIMENT + top movers.
VITE_CATALYST_TOPICS=mergers_and_acquisitions,earnings,financial_markets
VITE_CATALYST_SCAN_MS=300000
VITE_BENZINGA_API_KEY=

# Futures proxy endpoint. Point this to your own server/Supabase function that talks to
# Databento, CME, Interactive Brokers, Tradovate, or another licensed futures feed.
VITE_FUTURES_PROXY_URL=
VITE_FUTURES_SYMBOLS=

# Polling interval in milliseconds.
VITE_LIVE_POLL_MS=300000

# Server-side variables for supabase/functions/live-market-data.
# ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY=
# BENZINGA_API_KEY=
# REUTERS_LSEG_API_KEY=
# DOW_JONES_API_KEY=
# FUTURES_PROXY_URL=
# Real business agent connectors. Point these at server-side endpoints that hold
# provider credentials and return execution receipts. Never place provider
# secret keys in VITE_* variables.
VITE_AGENT_CRM_WEBHOOK_URL=
VITE_AGENT_OUTREACH_WEBHOOK_URL=
VITE_AGENT_STOREFRONT_WEBHOOK_URL=
VITE_AGENT_PAYMENTS_WEBHOOK_URL=
VITE_AGENT_FULFILLMENT_WEBHOOK_URL=
